{"kind":"table","sheet":"00_Cách dùng","address":"A1:H12","rows":12,"cols":8,"values":[["KMS - Runbook trực quan FL-01 đến FL-04",null,null,null,null,null,null,null],["Bản cập nhật sau khi hoàn thành FL-04. Dùng để demo end-to-end trên prototype FrontEnd mock data, không cần backend.",null,null,null,null,null,null,null],[null,null,null,null,null,null,null,null],["Cách dùng nhanh: mở prototype tại http://127.0.0.1:5174/ → bấm Reset Demo → đi theo sheet 01 đến 04 hoặc sheet 05_E2E_Tổng hợp.",null,null,null,null,null,null,null],[null,null,null,null,null,null,null,null],["Mục","Bạn cần làm gì","Dữ liệu/vai trò cần nhớ","Kết quả mong muốn","Khi bị lệch thì xử lý","Ghi chú",null,null],["Chuẩn bị","Mở prototype và bấm Reset Demo","http://127.0.0.1:5174/","Dữ liệu quay về seed FL-01/02/03/04","Reload trang hoặc bấm Reset Demo lần nữa","Port hiện tại là 5174 vì 5173 đang bận",null,null],["Đổi vai trò","Dùng dropdown vai trò trên top bar","Field Technician, Contributor, Knowledge Manager, Administrator","Mỗi role thấy đúng nhóm thao tác demo","Chọn lại đúng role theo từng bước","Prototype không có login/backend",null,null],["Demo nhanh","Đi sheet 05_E2E_Tổng hợp","CTN-1108, KR-DEMO-001, SUB-2026-0043, SOPD-2026-0012","Đi được từ tìm kiếm đến publish tri thức/SOP","Dùng cột Mở nhanh để nhảy route","Phù hợp khi thời gian demo ít",null,null],["Demo chi tiết","Đi lần lượt sheet 01 đến 04","Mỗi dòng có data nhập cụ thể","Giải thích được mục tiêu và expected output từng FL","Quay lại sheet 06_Data Demo khi cần ID","Phù hợp khi giảng luồng sâu",null,null],["Kết thúc","Mở checklist cuối","Sheet 07_Checklist","Không bỏ sót role, data, nhánh phụ","Tick lại từng mục","Dùng để tổng duyệt trước báo cáo",null,null],[null,null,null,null,null,null,null,null]]}
